{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@vue-aria/types": ["packages/@vue-aria/types/src/index.ts"],
      "@vue-aria/utils": ["packages/@vue-aria/utils/src/index.ts"],
      "@vue-aria/ssr": ["packages/@vue-aria/ssr/src/index.ts"],
      "@vue-aria/live-announcer": ["packages/@vue-aria/live-announcer/src/index.ts"],
      "@vue-aria/focus": ["packages/@vue-aria/focus/src/index.ts"],
      "@vue-aria/i18n": ["packages/@vue-aria/i18n/src/index.ts"],
      "@vue-aria/interactions": ["packages/@vue-aria/interactions/src/index.ts"],
      "@vue-aria/button": ["packages/@vue-aria/button/src/index.ts"],
      "@vue-aria/checkbox": ["packages/@vue-aria/checkbox/src/index.ts"],
      "@vue-aria/radio": ["packages/@vue-aria/radio/src/index.ts"],
      "@vue-aria/switch": ["packages/@vue-aria/switch/src/index.ts"],
      "@vue-aria/tabs": ["packages/@vue-aria/tabs/src/index.ts"],
      "@vue-aria/slider": ["packages/@vue-aria/slider/src/index.ts"],
      "@vue-aria/progress": ["packages/@vue-aria/progress/src/index.ts"],
      "@vue-aria/meter": ["packages/@vue-aria/meter/src/index.ts"],
      "@vue-aria/datefield": ["packages/@vue-aria/datefield/src/index.ts"],
      "@vue-aria/datepicker": ["packages/@vue-aria/datepicker/src/index.ts"],
      "@vue-aria/calendar": ["packages/@vue-aria/calendar/src/index.ts"],
      "@vue-aria/breadcrumbs": ["packages/@vue-aria/breadcrumbs/src/index.ts"],
      "@vue-aria/disclosure": ["packages/@vue-aria/disclosure/src/index.ts"],
      "@vue-aria/listbox": ["packages/@vue-aria/listbox/src/index.ts"],
      "@vue-aria/selection": ["packages/@vue-aria/selection/src/index.ts"],
      "@vue-aria/link": ["packages/@vue-aria/link/src/index.ts"],
      "@vue-aria/label": ["packages/@vue-aria/label/src/index.ts"],
      "@vue-aria/textfield": ["packages/@vue-aria/textfield/src/index.ts"],
      "@vue-aria/searchfield": ["packages/@vue-aria/searchfield/src/index.ts"],
      "@vue-aria/select": ["packages/@vue-aria/select/src/index.ts"],
      "@vue-aria/numberfield": ["packages/@vue-aria/numberfield/src/index.ts"],
      "@vue-aria/spinbutton": ["packages/@vue-aria/spinbutton/src/index.ts"],
      "@vue-aria/separator": ["packages/@vue-aria/separator/src/index.ts"],
      "@vue-aria/visually-hidden": ["packages/@vue-aria/visually-hidden/src/index.ts"],
      "@vue-aria/vue-aria": ["packages/@vue-aria/vue-aria/src/index.ts"]
    },
    "strict": true,
    "declaration": true,
    "outDir": "dist",
    "skipLibCheck": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["packages/**/*.ts", "tests/**/*.ts", "vitest.config.ts"]
}
