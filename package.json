{
  "name": "vue-aria-port",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/@vue-aria/*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
