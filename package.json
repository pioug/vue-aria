    "@internationalized/number": "^3.6.5",
    "@internationalized/string": "^3.2.7",
    "aria-hidden": "^1.2.3",
    "clsx": "^2.1.1"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "@testing-library/user-event": "^14.6.1",
    "@testing-library/vue": "^8.1.0",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "vitepress": "^1.6.3",
    "vitest": "^2.1.8",
    "vue": "^3.5.13"
  }
