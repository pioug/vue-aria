{
  "name": "vue-aria-port",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/@vue-aria/*",
    "packages/@vue-spectrum/*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:parity": "node scripts/check-test-parity.mjs",
    "check:spectrum-workflow": "node scripts/check-spectrum-workflow.mjs",
    "test:spectrum-parity": "node scripts/check-spectrum-parity.mjs && node scripts/check-spectrum-workflow.mjs",
    "test:spectrum-case-parity": "node scripts/check-spectrum-testcase-parity.mjs",
    "test:spectrum-case-parity:diagnostics": "node scripts/check-spectrum-testcase-parity.mjs --include-local-only",
    "update:spectrum-case-tracker": "node scripts/check-spectrum-testcase-parity.mjs --write",
    "update:spectrum-case-tracker:diagnostics": "node scripts/check-spectrum-testcase-parity.mjs --write --include-local-only",
    "docs:style-alias-gaps": "node scripts/mine-spectrum-style-alias-gaps.mjs --write",
    "scaffold:spectrum-package": "node scripts/scaffold-spectrum-package.mjs",
    "test:cross-browser": "playwright test",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@internationalized/date": "^3.11.0",
    "@internationalized/message": "^3.1.8",
    "@internationalized/number": "^3.6.5",
    "@internationalized/string": "^3.2.7",
    "aria-hidden": "^1.2.3",
    "clsx": "^2.1.1"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "@playwright/test": "^1.51.1",
    "@testing-library/user-event": "^14.6.1",
    "@testing-library/vue": "^8.1.0",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "vitepress": "^1.6.3",
    "vitest": "^2.1.8",
    "vue": "^3.5.13"
  }
}
